# Grant the 'battery' group write access to charge threshold files
ACTION=="add|change", SUBSYSTEM=="power_supply", KERNEL=="BAT*", \
  GROUP="battery", MODE="0664", \
  RUN+="/bin/chgrp battery /sys/class/power_supply/%k/charge_control_start_threshold", \
  RUN+="/bin/chgrp battery /sys/class/power_supply/%k/charge_control_end_threshold"
